# 基本配置
APP_NAME=interactive-bot
BOT_TOKEN=123456789:replace-with-your-bot-token

# 业务配置
WELCOME_MESSAGE="你好，请问有什么可以帮助你的吗？"
# 各类内置 ID 可以通过 @GetTheirIDBot 获取
ADMIN_GROUP_ID=-1000000000000
ADMIN_USER_IDS=123456789,987654321

# 删除话题时是否永久封禁（无法恢复）TRUE 开启
DELETE_TOPIC_AS_FOREVER_BAN=FALSE

# 利用 /clear 清理后台和用户侧的所有消息（危险，不推荐）TRUE 开启
# 新版本默认建议保持 FALSE
DELETE_USER_MESSAGE_ON_CLEAR_CMD=FALSE

# 是否禁用人机识别 TRUE 禁用
DISABLE_CAPTCHA=FALSE

# 防止客户不停刷消息。单位：秒。0 为不限制
MESSAGE_INTERVAL=5

# 媒体组/相册延迟聚合转发时间，单位：秒
MEDIA_GROUP_DELAY=3

# 可选：数据库与持久化文件路径。默认写入 /app/data，适合 Docker volume。
DATABASE_URL=sqlite:///data/db.sqlite3
PERSISTENCE_PATH=/app/data/interactive-bot.pickle

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
